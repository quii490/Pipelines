/*
  Species-specific reference paths.
  params.species is supplied by run_pipeline.sh/run_auto_rnaseq.sh before this
  file is included, so every branch uses a self-consistent genome, annotation,
  STAR/HISAT2/Salmon index and TE reference.
*/

params.rediscoverte_dir = '/home/machicheng/softwares/REdiscoverTE'
params.rediscoverte_rollup_dir = '/home/machicheng/softwares/REdiscoverTE/original/REdiscoverTE/rollup_annotation'
params.salmonte_dir = '/home/machicheng/softwares/SalmonTE-0.4'

// Nextflow config files allow assignments and maps, but do not allow a
// procedural if/else block mixed with config statements. Select every
// reference from the same species-keyed map so the genome and annotations
// cannot silently come from different species.
params.rnaseq_species = (params.species ?: 'hg38').toString().trim().toLowerCase()
params.genome_fasta = [
    hg38: '/home/machicheng/reference/human_hg38/GRCh38.primary_assembly.genome.fa',
    mm10: '/home/machicheng/reference/mouse_mm10/GRCm38.primary_assembly.genome.fa',
    mm39: '/home/machicheng/reference/mouse_mm39/GRCm39.primary_assembly.genome.fa'
][params.rnaseq_species]
params.gtf_genes = [
    hg38: '/home/machicheng/reference/human_hg38/gencode.v49.primary_assembly.annotation.gtf',
    mm10: '/home/machicheng/reference/mouse_mm10/gencode.vM25.primary_assembly.annotation.gtf',
    mm39: '/home/machicheng/reference/mouse_mm39/gencode.vM38.primary_assembly.annotation.gtf'
][params.rnaseq_species]
params.star_index = [
    hg38: '/home/machicheng/reference/STAR_index/hg38',
    mm10: '/home/machicheng/reference/STAR_index/mm10',
    mm39: '/home/machicheng/reference/STAR_index/mm39'
][params.rnaseq_species]
params.hisat2_index = [
    hg38: '/home/machicheng/reference/HISAT2_index/hg38/hg38',
    mm10: '/home/machicheng/reference/HISAT2_index/mm10/mm10_index',
    mm39: '/home/machicheng/reference/HISAT2_index/mm39/mm39_index'
][params.rnaseq_species]
params.salmon_index = [
    hg38: '/home/machicheng/reference/salmon_index/salmon_index_decoy_hg38',
    mm10: '/home/machicheng/reference/salmon_index/salmon_index_decoy_mm10',
    mm39: '/home/machicheng/reference/salmon_index/salmon_index_decoy_mm39'
][params.rnaseq_species]
params.gtf_te = [
    hg38: '/home/machicheng/reference/TE_GTF/hg38_rmsk_TE.gtf',
    mm10: '/home/machicheng/reference/TE_GTF/mm10_rmsk_TE.gtf',
    mm39: '/home/machicheng/reference/TE_GTF/mm39_rmsk_TE.gtf'
][params.rnaseq_species]
params.telocal_index = [
    hg38: '/home/machicheng/reference/TElocal/hg38_rmsk_TE.gtf.locInd',
    mm10: '/home/machicheng/reference/TElocal/mm10_rmsk_TE.gtf.locInd',
    mm39: '/home/machicheng/reference/TElocal/mm39_rmsk_TE.gtf.locInd'
][params.rnaseq_species]
params.salmonte_ref = [hg38: 'hs', mm10: 'mm', mm39: 'mm'][params.rnaseq_species]
params.blacklist = [
    hg38: '/home/machicheng/reference/blacklist/hg38-blacklist.v2.bed',
    mm10: '/home/machicheng/reference/blacklist/mm10-blacklist.v2.bed',
    mm39: '/home/machicheng/reference/blacklist/mm39.excluderanges.bed'
][params.rnaseq_species]
params.rmsk = [
    hg38: '/home/machicheng/reference/TE_GTF/rmsk/hg38_rmsk.bed.gz',
    mm10: '/home/machicheng/reference/TE_GTF/rmsk/mm10_rmsk.bed.gz',
    mm39: '/home/machicheng/reference/TE_GTF/rmsk/mm39_rmsk.bed.gz'
][params.rnaseq_species]
params.rediscoverte_salmon_index = '/home/machicheng/reference/REdiscoverTE/REdiscoverTE'
