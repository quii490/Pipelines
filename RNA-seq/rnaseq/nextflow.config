manifest.name = 'rnaseq-multitool-fixed'

/*
 * -----------------------------
 * Default run parameters
 * -----------------------------
 */
params.samplesheet      = null
params.outdir           = 'results'
params.species          = 'hg38'
params.human_ref        = 'hg38'
params.aligner          = 'star'
params.strandedness     = 'reverse'
params.failure_policy   = 'core'

params.run_fastp        = true
params.run_star_fc      = true
params.run_salmon       = true
params.run_stringtie    = false
params.run_tecount      = false
params.run_telocal      = false
params.run_rediscoverte = true
params.run_salmonte     = false
params.run_tetranscripts = true
params.run_telescope    = true
params.run_fastqc       = true
// Raw REdiscoverTE quant.sf files are consumed directly by downstream. Rollup
// uses the pre-built downstream R environment so it does not trigger a large
// Conda solve during a normal RNA-seq run.
params.run_rediscoverte_rollup = true
params.run_dedup = false
params.run_markdup_qc = true
params.run_rnaseq_metrics = true
params.run_multiqc = true
/*
 * -----------------------------
 * Global resource controls
 * Override on CLI, e.g.
 * --max_cpus 30 --max_memory '300 GB'
 * -----------------------------
 */
params.max_cpus         = 30
params.max_memory       = '300 GB'
params.max_time         = '240h'
params.queue_size       = 8

/*
 * -----------------------------
 * Per-process resource defaults
 * -----------------------------
 */
params.check_cpus         = 1
params.check_mem          = '1 GB'

params.fastp_cpus         = 4
params.fastp_mem          = '8 GB'

params.fastqc_cpus        = 4
params.fastqc_mem         = '4 GB'

params.star_cpus          = 12
params.star_mem           = '48 GB'

/*
 * STAR tuning is split by branch.
 * Gene quantification should stay splice-aware and relatively conservative.
 * TE quantification needs multimapping alignments retained for TEcount/TElocal/TEtranscripts.
 */
params.star_gene_multimap_nmax              = 20
params.star_gene_win_anchor_multimap_nmax   = 50
params.star_gene_mismatch_nmax              = 999
params.star_gene_mismatch_nover_read_lmax   = 0.04

params.star_te_multimap_nmax                = 100
params.star_te_win_anchor_multimap_nmax     = 50
params.star_te_out_sam_mult_nmax            = -1
params.star_te_mismatch_nmax                = 999
params.star_te_mismatch_nover_read_lmax     = 0.10
params.star_te_align_intron_max             = 1

params.hisat2_cpus        = 12
params.hisat2_mem         = '48 GB'

params.fc_cpus            = 4
params.fc_mem             = '8 GB'

params.dedup_cpus         = 4
params.dedup_mem          = '24 GB'
// Keep Picard's JVM heap below the task memory limit so MarkDuplicates does
// not fall back to the conda wrapper's small default heap.
params.picard_markdup_java_heap = '16g'

params.salmon_cpus        = 8
params.salmon_mem         = '24 GB'

params.stringtie_cpus     = 6
params.stringtie_mem      = '16 GB'

// TEcount/TElocal are single-process Python tools in the current commands.
// Reserve one CPU per sample and use controlled sample-level parallelism.
params.tecount_cpus       = 1
params.tecount_mem        = '16 GB'
params.tecount_max_forks  = 4

params.telocal_cpus       = 1
params.telocal_mem        = '16 GB'
params.telocal_max_forks  = 4

params.tequant_cpus       = 1
params.tequant_mem        = '16 GB'
params.tequant_max_forks  = 4

params.rediscoverte_cpus  = 8
params.rediscoverte_mem   = '16 GB'
params.rediscoverte_max_forks = 3

params.rediscoverte_rollup_cpus = 6
params.rediscoverte_rollup_mem  = '16 GB'
params.rediscoverte_rollup_conda_prefix = '/path/to/.conda/envs/downstream'

params.salmonte_cpus      = 6
params.salmonte_mem       = '16 GB'
params.salmonte_max_forks = 1

params.telescope_cpus     = 4
params.telescope_mem      = '32 GB'
params.telescope_max_forks = 2

params.rnaseq_metrics_cpus = 2
params.rnaseq_metrics_mem  = '12 GB'
params.rnaseq_metrics_java_heap = '8g'
params.rnaseq_metrics_strand = null

params.multiqc_cpus       = 2
params.multiqc_mem        = '8 GB'
params.multiqc_cmd        = '/path/to/.conda/envs/emseq/bin/multiqc'
params.multiqc_time       = '2h'

/*
 * -----------------------------
 * Optional files
 * -----------------------------
 */
params.blacklist = params.blacklist ?: null
params.ref_flat = params.ref_flat ?: null
params.ribosomal_intervals = params.ribosomal_intervals ?: null

/*
 * -----------------------------
 * Load species-specific references
 * conf/species_refs.config should define:
 * genome_fasta, gtf_genes, star_index, hisat2_index, salmon_index,
 * gtf_te, telocal_index, salmonte_dir, salmonte_ref,
 * and for hg38 optionally rediscoverte_* params
 * -----------------------------
 */
includeConfig 'conf/species_refs.config'

/*
 * -----------------------------
 * Executor controls
 * queueSize controls concurrent task submission
 * -----------------------------
 */
executor {
  name = 'local'
  queueSize = params.queue_size as int
}

process {
  conda = '/path/to/.conda/envs/rnaseq'
  executor = 'local'
  errorStrategy = 'terminate'
  maxRetries = 1
  cpus = 1
  memory = '2 GB'
  time = params.max_time

  resourceLimits = [
    cpus: params.max_cpus as int,
    memory: params.max_memory
  ]

  withName: 'CHECK_REFS' {
    cpus = params.check_cpus
    memory = params.check_mem
  }

  withName: 'FASTP_PE' {
    cpus = params.fastp_cpus
    memory = params.fastp_mem
  }

  withName: 'FASTP_SE' {
    cpus = params.fastp_cpus
    memory = params.fastp_mem
  }

  withName: 'FASTQC_PE' {
    cpus = params.fastqc_cpus
    memory = params.fastqc_mem
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'FASTQC_SE' {
    cpus = params.fastqc_cpus
    memory = params.fastqc_mem
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'STAR_ALIGN_GENE_PE' {
    cpus = params.star_cpus
    memory = params.star_mem
    maxRetries = 2
    errorStrategy = 'retry'
  }

  withName: 'STAR_ALIGN_GENE_SE' {
    cpus = params.star_cpus
    memory = params.star_mem
    maxRetries = 2
    errorStrategy = 'retry'
  }

  withName: 'HISAT2_ALIGN_GENE_PE' {
    cpus = params.hisat2_cpus
    memory = params.hisat2_mem
    maxRetries = 2
    errorStrategy = 'retry'
  }

  withName: 'HISAT2_ALIGN_GENE_SE' {
    cpus = params.hisat2_cpus
    memory = params.hisat2_mem
    maxRetries = 2
    errorStrategy = 'retry'
  }

  withName: 'FEATURECOUNTS_GENE' {
    cpus = params.fc_cpus
    memory = params.fc_mem
  }

  withName: 'MARKDUP_GENE_BAM' {
    cpus = params.dedup_cpus
    memory = params.dedup_mem
  }

  withName: 'MARKDUP_TE_BAM' {
    cpus = params.dedup_cpus
    memory = params.dedup_mem
  }

  withName: 'MARKDUP_GENE_QC' {
    cpus = params.dedup_cpus
    memory = params.dedup_mem
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'MARKDUP_TE_QC' {
    cpus = params.dedup_cpus
    memory = params.dedup_mem
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'RNASEQ_METRICS' {
    cpus = params.rnaseq_metrics_cpus
    memory = params.rnaseq_metrics_mem
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'PREP_REFFLAT' {
    cpus = 1
    memory = '4 GB'
  }

  withName: 'STRINGTIE_ASSEMBLY' {
    cpus = params.stringtie_cpus
    memory = params.stringtie_mem
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'SALMON_GENE_PE' {
    cpus = params.salmon_cpus
    memory = params.salmon_mem
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'SALMON_GENE_SE' {
    cpus = params.salmon_cpus
    memory = params.salmon_mem
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'STAR_ALIGN_TE_PE' {
    cpus = params.star_cpus
    memory = params.star_mem
   maxRetries = 2
    errorStrategy = { task.attempt < 2 ? 'retry' : (params.failure_policy == 'strict' ? 'terminate' : 'ignore') }
  }

  withName: 'STAR_ALIGN_TE_SE' {
    cpus = params.star_cpus
    memory = params.star_mem
    maxRetries = 2
    errorStrategy = { task.attempt < 2 ? 'retry' : (params.failure_policy == 'strict' ? 'terminate' : 'ignore') }
  }

  withName: 'TECOUNT_SAMPLE' {
    cpus = params.tecount_cpus
    memory = params.tecount_mem
    maxForks = params.tecount_max_forks
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'TE_QUANT' {
    cpus = params.tequant_cpus
    memory = params.tequant_mem
    maxForks = params.tequant_max_forks
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'TELOCAL_SAMPLE' {
    cpus = params.telocal_cpus
    memory = params.telocal_mem
    maxForks = params.telocal_max_forks
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'REDISCOVERTE_QUANT_PE' {
    cpus = params.rediscoverte_cpus
    memory = params.rediscoverte_mem
    maxForks = params.rediscoverte_max_forks
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'REDISCOVERTE_QUANT_SE' {
    cpus = params.rediscoverte_cpus
    memory = params.rediscoverte_mem
    maxForks = params.rediscoverte_max_forks
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'REDISCOVERTE_ROLLUP' {
    cpus = params.rediscoverte_rollup_cpus
    memory = params.rediscoverte_rollup_mem
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'SALMONTE_SAMPLE_PE' {
    cpus = params.salmonte_cpus
    memory = params.salmonte_mem
    maxForks = params.salmonte_max_forks
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'SALMONTE_SAMPLE_SE' {
    cpus = params.salmonte_cpus
    memory = params.salmonte_mem
    maxForks = params.salmonte_max_forks
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'PREP_TELESCOPE_ANNOTATION' {
    cpus = 1
    memory = '4 GB'
  }

  withName: 'TELESCOPE_ASSIGN' {
    cpus = params.telescope_cpus
    memory = params.telescope_mem
    maxForks = params.telescope_max_forks
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }

  withName: 'MULTIQC_REPORT' {
    cpus = params.multiqc_cpus
    memory = params.multiqc_mem
    time = params.multiqc_time
    errorStrategy = params.failure_policy == 'strict' ? 'terminate' : 'ignore'
  }
}

/*
 * -----------------------------
 * Conda / containers
 * -----------------------------
 */
params.conda_cache_dir = params.conda_cache_dir ?: "${params.outdir}/_automation/conda_cache"

conda {
  enabled = true
  cacheDir = params.conda_cache_dir
  channels = ['conda-forge', 'bioconda', 'defaults']
  createOptions = '--strict-channel-priority'
  createTimeout = '2 h'
}

docker {
  enabled = false
}

singularity {
  enabled = false
}

/*
 * -----------------------------
 * Run reports
 * overwrite=true avoids repeated-run collisions
 * -----------------------------
 */
timeline {
  enabled = true
  file = "${params.outdir}/pipeline_timeline.html"
  overwrite = true
}

report {
  enabled = true
  file = "${params.outdir}/pipeline_report.html"
  overwrite = true
}

trace {
  enabled = true
  file = "${params.outdir}/pipeline_trace.txt"
  overwrite = true
}

dag {
  enabled = true
  file = "${params.outdir}/pipeline_dag.html"
  overwrite = true
}

/*
 * -----------------------------
 * Useful profiles
 * -----------------------------
 */
profiles {

  debug {
    process.echo = true
  }

  small {
    params.max_cpus   = 16
    params.max_memory = '128 GB'
    params.queue_size = 2

    params.fastp_cpus = 2
    params.fastp_mem  = '4 GB'

    params.star_cpus  = 6
    params.star_mem   = '24 GB'

    params.salmon_cpus = 4
    params.salmon_mem  = '8 GB'
  }

  large {
    params.max_cpus   = 30
    params.max_memory = '300 GB'
    params.queue_size = 4

    params.fastp_cpus = 4
    params.fastp_mem  = '8 GB'

    params.star_cpus  = 8
    params.star_mem   = '32 GB'

    params.salmon_cpus = 8
    params.salmon_mem  = '16 GB'
  }
}
