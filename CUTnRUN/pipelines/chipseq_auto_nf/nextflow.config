params {
    manifest                    = null
    outdir                      = 'results_chipseq_auto'
    assay                       = 'chipseq'
    trim                        = true
    run_analysis                = true
    make_rpgc_track             = true
    download_threads            = 8
    min_mapq                    = 30
    min_frag                    = 30
    max_frag                    = 1200
    extend_reads_se             = 250
    ignore_for_normalization    = 'chrX'
    macs_cmd                    = 'macs3'
    macs_qvalue                 = null   // e.g. 0.01 stricter, 0.1 more relaxed; null uses MACS default
    macs_pvalue                 = null   // if set, MACS uses -p instead of -q
    macs_broad_cutoff           = null   // broad peak cutoff; e.g. 0.05 stricter, 0.2 more relaxed
    macs_cutoff_analysis        = false  // diagnostic cutoff scan is slow; enable only when requested

    min_total_normalized_counts = 10
    n_labels_genes              = 20
    n_labels_te_family          = 20
    n_labels_te_repname         = 40
    // Large TE count matrices can contain millions of copies.  Keep the
    // analytical tables complete, but cap only display-layer point/facet data.
    max_te_plot_rows             = 200000
    max_te_scatter_points        = 100000
    max_te_facet_levels          = 100
    te_classes                  = ['LTR','LINE','SINE']

    make_te_tracks              = true
    make_te_locus_best_track    = true
    te_k                        = 25
    te_min_mapq                 = 0
    te_exclude_flags            = 4
    te_proper_pair_only         = true
    te_remove_blacklist         = false
    te_duplicate_policy         = 'mark'
    te_bw_binsize               = 10
    te_track_normalization      = 'RPGC'
    te_locus_best_binsize       = 5

    /*
      Only bowtie2_index usually needs local editing.
      Annotation files below point to the maintained resources directory:
        /path/to/CUTnRUN/resources/CUTRUN_analysis/anno
    */
    references = [
        hg38: [
            bowtie2_index        : '/path/to/reference/bowtie2_index/bowtie2_index_hg38/hg38',
            gene_saf             : '/path/to/CUTnRUN/resources/CUTRUN_analysis/anno/gene_hg38.saf',
            te_saf               : '/path/to/CUTnRUN/resources/CUTRUN_analysis/anno/te_hg38.saf',
            gene_anno            : '/path/to/CUTnRUN/resources/CUTRUN_analysis/anno/gene_anno_ensembl_hg38.tsv',
            te_anno              : '/path/to/CUTnRUN/resources/CUTRUN_analysis/anno/te_anno_hg38.tsv',
            blacklist            : '/path/to/CUTnRUN/resources/CUTRUN_analysis/anno/hg38-blacklist.v2.bed',
            effective_genome_size: 2913022398,
            macs2_genome         : 'hs',
            clean_regex          : '(^chrM$|_random|_alt|_fix|chrUn|^GL|^KI)'
        ],
        mm39: [
            bowtie2_index        : '/path/to/reference/bowtie2_index/bowtie2_index_GRCm39/GRCm39',
            gene_saf             : '/path/to/CUTnRUN/resources/CUTRUN_analysis/anno/gene_mm39.saf',
            te_saf               : '/path/to/CUTnRUN/resources/CUTRUN_analysis/anno/te_mm39.saf',
            gene_anno            : '/path/to/CUTnRUN/resources/CUTRUN_analysis/anno/gene_anno_ensembl_mm39.tsv',
            te_anno              : '/path/to/CUTnRUN/resources/CUTRUN_analysis/anno/te_anno_mm39.tsv',
            blacklist            : '/path/to/CUTnRUN/resources/CUTRUN_analysis/anno/mm39-blacklist.v2.bed',
            effective_genome_size: 2652783500,
            macs2_genome         : 'mm',
            clean_regex          : '(^chrM$|_random|_alt|_fix|chrUn|^GL|^JH)'
        ]
    ]
}

process {
    executor = 'local'
    cpus = 8
    memory = '16 GB'
    time = '12h'
    errorStrategy = 'retry'
    maxRetries = 1

    withName: RESOLVE_MANIFEST { cpus = 2;  memory = '4 GB';  time = '12h' }
    withName: PREP_READS       { cpus = 8;  memory = '16 GB'; time = '12h' }
    withName: ALIGN            { cpus = 16; memory = '24 GB'; time = '24h' }
    withName: ALIGN_TE         { cpus = 16; memory = '32 GB'; time = '24h'; maxRetries = 3 }
    withName: SORT_BAM         { cpus = 8;  memory = '16 GB'; time = '12h' }
    withName: SORT_BAM_TE      { cpus = 8;  memory = '24 GB'; time = '12h' }
    withName: CLEAN_BAM        { cpus = 8;  memory = '16 GB'; time = '12h' }
    withName: CLEAN_BAM_TE     { cpus = 8;  memory = '32 GB'; time = '24h' }
    withName: BIGWIG           { cpus = 8;  memory = '12 GB'; time = '12h' }
    withName: BIGWIG_TE        { cpus = 8;  memory = '12 GB'; time = '12h' }
    withName: TE_LOCUS_BEST_BAM { cpus = 8; memory = '12 GB'; time = '12h' }
    withName: BIGWIG_TE_LOCUS_BEST { cpus = 8; memory = '12 GB'; time = '12h' }
    withName: CALL_PEAKS       { cpus = 4;  memory = '8 GB';  time = '12h' }
    withName: FEATURECOUNTS_GENE { cpus = 8; memory = '24 GB'; time = '12h' }
    withName: FEATURECOUNTS_TE { cpus = 16; memory = '32 GB'; time = '24h' }
    withName: RUN_ANALYSIS     { cpus = 4;  memory = '16 GB'; time = '12h' }
}

profiles {
    standard { process.executor = 'local' }

    conda {
        conda.enabled = true
        conda.useMamba = true
        process.conda = '/path/to/.conda/envs/chipseq'
    }
}

timeline.enabled = true
timeline.overwrite = true
report.enabled = true
report.overwrite = true
trace.enabled = true
trace.overwrite = true
dag.enabled = false

manifest {
    name = 'chipseq-auto-nextflow'
}
